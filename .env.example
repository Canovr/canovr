# CanovR Auth Konfiguration
# Kopiere diese Datei als .env und trage die echten Werte ein.

# JWT Signing Key (generiere z.B. mit: python3 -c "import secrets; print(secrets.token_hex(32))")
CANOVR_JWT_SECRET=
# Optional eigener Secret nur fuer OAuth-State (falls leer -> Fallback auf CANOVR_JWT_SECRET)
# CANOVR_OAUTH_STATE_SECRET=

# Strava OAuth
STRAVA_CLIENT_ID=214640
STRAVA_CLIENT_SECRET=

# Optional: Turso DB (Production)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# iOS Universal-Link / AASA
# CANOVR_APPLE_TEAM_ID=M944LR67TZ
# CANOVR_IOS_BUNDLE_ID=com.canovr.app

# App Debug-Modus (Production: false)
# CANOVR_DEBUG=false

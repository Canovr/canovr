# CanovR Auth Konfiguration
# Kopiere diese Datei als .env und trage die echten Werte ein.

# JWT Signing Key (generiere z.B. mit: python3 -c "import secrets; print(secrets.token_hex(32))")
CANOVR_JWT_SECRET=

# Strava OAuth
STRAVA_CLIENT_ID=214640
STRAVA_CLIENT_SECRET=

# Optional: Turso DB (Production)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
